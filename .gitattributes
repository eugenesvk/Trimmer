* text=auto

*.cmd           text    eol=crlf
.env            text
.env.example    text

# Tell Package Control to ignore packaging these files tagged w/ "export-ignore"
# See: math2001/FileManager#41 (comment) https://github.com/math2001/FileManager/pull/41#issuecomment-554541489
.env            export-ignore
.env.example    export-ignore

# Git & Github
.github/      	export-ignore
.gitattributes	export-ignore
.gitignore    	export-ignore

# Documentation
doc/           	export-ignore
sample/        	export-ignore
screenshots/   	export-ignore
Contributing.md	export-ignore
ToDo.md        	export-ignore
2Do.md         	export-ignore

# Tests
tests/   	export-ignore
test/    	export-ignore
\[test\]/	export-ignore

# Settings
.editorconfig	export-ignore

# Source files
src/     export-ignore
